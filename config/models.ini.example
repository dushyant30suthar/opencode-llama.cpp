version = 1

# Per-model settings — YOURS TO EDIT. New models get a default section appended;
# existing sections are never modified or removed by opencode.
# Any llama-server flag works as a key (without leading dashes). Common ones:
#   ctx-size = 32768          context window tokens
#   gpu-layers = 99           layers offloaded to GPU (99 = all)
#   tensor-split = 0.67,0.33  VRAM ratio across the two GPUs
#   cache-type-k = q8_0       KV cache quant: f16 | q8_0 | q4_0
#   cache-type-v = q8_0
#   flash-attn = on
#   temp = 0.7                sampling temperature
#   reasoning-preserve = true keep <think> blocks in multi-turn history (thinking
#                             models loop/repeat tool calls without it; template
#                             support auto-detected, see router.log)
# QWEN3.6 THINKING SAMPLERS (official "precise coding" card values):
#   temp = 0.6, top-p = 0.95, top-k = 20, min-p = 0
# CHAT PROFILE (max generation speed, 152 t/s on the 35B; prompt speed -30%):
#   split-mode = tensor, ubatch-size = 2048
# SPEED PROFILE (alternative to max-context): for snappier agent turns use
#   ctx-size = 65536, cache-type-k/v = f16, spec-type = ngram-mod
# (draft-free speculative decoding conflicts with quantized KV cache).
# Changes apply on next model load (restart the router or swap models).

[lmstudio-community/gemma-4-31B-it-QAT-GGUF]
model = ~/.lmstudio/models/lmstudio-community/gemma-4-31B-it-QAT-GGUF/gemma-4-31B-it-QAT-Q4_0.gguf
mmproj = ~/.lmstudio/models/lmstudio-community/gemma-4-31B-it-QAT-GGUF/mmproj-gemma-4-31B-it-QAT-BF16.gguf
ctx-size = 147456
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
# host prompt-cache cap: default 8GiB+ swamped the 32GB box (24GB swapped)
cache-ram = 2048

[lmstudio-community/Qwen3.6-27B-GGUF]
model = ~/.lmstudio/models/lmstudio-community/Qwen3.6-27B-GGUF/Qwen3.6-27B-Q4_K_M.gguf
# vision (mmproj) removed by choice — frees ~900MB VRAM for full 256k context
ctx-size = 258048
ubatch-size = 2048
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
# host prompt-cache cap: default 8GiB+ swamped the 32GB box (24GB swapped)
# host prompt-cache DISABLED: cap does not hold on hybrid arch (2048 cap
# → 26.8GB swapped, 2026-07-10; restore is inert on hybrids anyway)
cache-ram = 0
# keep thinking in history — prevents tool-call loops, keeps KV prefix cache hot
reasoning-preserve = true
# official Qwen3.6 thinking "precise coding" samplers
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0

[lmstudio-community/Qwen3.6-35B-A3B-GGUF]
model = ~/.lmstudio/models/lmstudio-community/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-Q4_K_M.gguf
mmproj = ~/.lmstudio/models/lmstudio-community/Qwen3.6-35B-A3B-GGUF/mmproj-Qwen3.6-35B-A3B-BF16.gguf
ctx-size = 245760
ubatch-size = 2048
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
# host prompt-cache cap: default 8GiB+ swamped the 32GB box (24GB swapped)
# host prompt-cache DISABLED: cap does not hold on hybrid arch (2048 cap
# → 26.8GB swapped, 2026-07-10; restore is inert on hybrids anyway)
cache-ram = 0
# keep thinking in history — prevents tool-call loops, keeps KV prefix cache hot
reasoning-preserve = true
# official Qwen3.6 thinking "precise coding" samplers
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0

# Q5_K_XL of the MTP 27B — one quality tier up over Q4_XL, same quality/speed budget.
# ctx-size 180224: PROBED 2026-07-10 (bisect + load-and-generate verification) —
#   full parity with Q4_XL; the hybrid attention's light KV leaves the headroom.
# ubatch-size 1024: NOT probed for this model — smaller compute buffers than Q4's
#   2048 to stay safe on VRAM at 180k (bigger Q5 weights). Raise to 2048 and test
#   if you want max prompt speed and it still loads.
[unsloth/Qwen3.6-27B-MTP:Q5_K_XL]
model = ~/.lmstudio/models/unsloth/Qwen3.6-27B-MTP-GGUF/Qwen3.6-27B-UD-Q5_K_XL.gguf
ctx-size = 180224
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
ubatch-size = 1024
parallel = 1
spec-type = draft-mtp
# n-max 4 = your proven champion value. A 2026-07-10 probe found 2/3/4 within
# ~1 t/s (noise) on a single run; restored 4 rather than change on noise.
spec-draft-n-max = 4
# host prompt-cache DISABLED: cap does not hold on hybrid arch (2048 cap
# → 26.8GB swapped, 2026-07-10; restore is inert on hybrids anyway)
cache-ram = 0
reasoning-preserve = true
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0

# MTP build of the 27B: built-in multi-token-prediction speculative decoding.
# Requires single slot (parallel = 1); vision unsupported with MTP.
[unsloth/Qwen3.6-27B-MTP-GGUF]
model = ~/.lmstudio/models/unsloth/Qwen3.6-27B-MTP-GGUF/Qwen3.6-27B-UD-Q4_K_XL.gguf
ctx-size = 180224
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
ubatch-size = 2048
parallel = 1
spec-type = draft-mtp
# n-max 4 = your original proven champion (70.6 t/s). Kept — see Q5 note above.
spec-draft-n-max = 4
# host prompt-cache DISABLED: cap does not hold on hybrid arch (2048 cap
# → 26.8GB swapped, 2026-07-10; restore is inert on hybrids anyway)
cache-ram = 0
# ctx-checkpoints: rollback points for prompt reuse, ~280MB host RAM each,
# ring covers the last N REQUESTS. Fewer than default (32) = frequent full
# 30s prompt re-evals — measured 2026-07-10. Stock 32 is correct; the one-off
# OOM needed 200k compaction + 20GB download at once. If a freeze ever recurs
# during compaction, lower this (16), not cache-ram.
# keep thinking in history — prevents tool-call loops, keeps KV prefix cache hot
reasoning-preserve = true
# official Qwen3.6 thinking "precise coding" samplers
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0
