version = 1

# Per-model settings — YOURS TO EDIT. New models get a default section appended;
# existing sections are never modified or removed by opencode.
# Any llama-server flag works as a key (without leading dashes). Common ones:
#   ctx-size = 32768          context window tokens
#   gpu-layers = 99           layers offloaded to GPU (99 = all)
#   tensor-split = 0.67,0.33  VRAM ratio across the two GPUs
#   cache-type-k = q8_0       KV cache quant: f16 | q8_0 | q4_0
#   cache-type-v = q8_0
#   flash-attn = on
#   temp = 0.7                sampling temperature
#   reasoning-preserve = true keep <think> blocks in multi-turn history (thinking
#                             models loop/repeat tool calls without it; template
#                             support auto-detected, see router.log)
# QWEN3.6 THINKING SAMPLERS (official "precise coding" card values):
#   temp = 0.6, top-p = 0.95, top-k = 20, min-p = 0
# CHAT PROFILE (max generation speed, 152 t/s on the 35B; prompt speed -30%):
#   split-mode = tensor, ubatch-size = 2048
# SPEED PROFILE (alternative to max-context): for snappier agent turns use
#   ctx-size = 65536, cache-type-k/v = f16, spec-type = ngram-mod
# (draft-free speculative decoding conflicts with quantized KV cache).
# Changes apply on next model load (restart the router or swap models).

[lmstudio-community/gemma-4-31B-it-QAT-GGUF]
model = ~/.lmstudio/models/lmstudio-community/gemma-4-31B-it-QAT-GGUF/gemma-4-31B-it-QAT-Q4_0.gguf
mmproj = ~/.lmstudio/models/lmstudio-community/gemma-4-31B-it-QAT-GGUF/mmproj-gemma-4-31B-it-QAT-BF16.gguf
ctx-size = 147456
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
# host prompt-cache cap: default 8GiB+ swamped the 32GB box (24GB swapped)
cache-ram = 2048
[lmstudio-community/Qwen3.6-35B-A3B-GGUF]
model = ~/.lmstudio/models/lmstudio-community/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-Q4_K_M.gguf
mmproj = ~/.lmstudio/models/lmstudio-community/Qwen3.6-35B-A3B-GGUF/mmproj-Qwen3.6-35B-A3B-BF16.gguf
ctx-size = 245760
ubatch-size = 2048
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
# host prompt-cache cap: default 8GiB+ swamped the 32GB box (24GB swapped)
# host prompt-cache DISABLED: cap does not hold on hybrid arch (2048 cap
# → 26.8GB swapped, 2026-07-10; restore is inert on hybrids anyway)
cache-ram = 0
# keep thinking in history — prevents tool-call loops, keeps KV prefix cache hot
reasoning-preserve = true
# official Qwen3.6 thinking "precise coding" samplers
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0
[michaelw9999/Qwen3.6-27B-NVFP4-MTP-GGUF]
model = ~/.lmstudio/models/michaelw9999/Qwen3.6-27B-NVFP4-MTP-GGUF/Qwen3.6-27B-NVFP4-MTP-GGUF.gguf
# 192k: sweet spot below probed max 212992 — 208896 left ~0.3G VRAM free, 196608 keeps ~0.9G
# on the tighter GPU (15.4/16.3 measured). q8_0 KV ≈ 0.18GB per 4096 tokens here.
ctx-size = 196608
gpu-layers = 99
flash-attn = on
cache-type-k = q8_0
cache-type-v = q8_0
jinja = true
split-mode = tensor
ubatch-size = 2048
parallel = 1
spec-type = draft-mtp
# n-max 3 = measured peak for NVFP4 (76.3 t/s vs 73.2 @ n4, 69.0 @ n5 — 2026-07-10 bench)
spec-draft-n-max = 3
# host prompt-cache DISABLED: cap does not hold on hybrid arch
cache-ram = 0
reasoning-preserve = true
# official Qwen3.6 thinking "precise coding" samplers
temp = 0.6
top-p = 0.95
top-k = 20
min-p = 0
